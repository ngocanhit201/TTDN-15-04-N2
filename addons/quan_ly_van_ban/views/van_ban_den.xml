<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_van_ban_den_form" model="ir.ui.view">
            <field name="name">van_ban_den</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Văn bản đến </div>
                        <group col="4" string="Thông tin chung">
                            <field name="so_hieu" />
                            <field name="tieu_de"/>
                            <field name="nguoi_gui"/>
                            <field name= "id_nguoi_nhan"/>
                            <field name="ngay_gui"/> 
                            <field name="id_co_quan_nhan"/>
                            <field name="trich_yeu" />
                            <field name="ngay_den" />
                            <field name="id_loai_van_ban" />
                            <field name="id_do_mat" />
                            <field name="id_nam" />

                            <field name="co_quan_ban_hanh" />
                            <!-- <field name="ids_cong_viec" /> -->

                            <field name="tep_dinh_kem" widget="pdf_viewer" />

                        </group>
                        <notebook>
                            <page string="Cong viec">
                                <field name="ids_cong_viec" />
                            </page>

                        </notebook>
                    </sheet>

                </form>
            </field>
        </record>

        <record id="view_van_ban_den_tree" model="ir.ui.view">
            <field name="name">van_ban_den</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="so_hieu" />
                    <field name="tieu_de"/>
                    <field name="nguoi_gui"/>
                    <field name= "id_nguoi_nhan"/>
                    <field name="ngay_gui"/> 
                    <field name="id_co_quan_nhan"/>
                    <field name="trich_yeu" />
                    <field name="ngay_den" />
                    <field name="id_loai_van_ban" />
                    <field name="id_do_mat" />
                    <field name="co_quan_ban_hanh" />
                    <field name="id_nam" />
                    

                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="van_ban_den_search">
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <search>
                    <field name="so_hieu" />
                    <field name="tieu_de"/>
                    <field name="nguoi_gui"/>
                    <field name= "id_nguoi_nhan"/>
                    <field name="ngay_gui"/> 
                    <field name="id_co_quan_nhan"/>
                    <field name="trich_yeu" />
                    <field name="id_loai_van_ban" />
                </search>
            </field>
        </record>
        <record id="action_van_ban_den" model="ir.actions.act_window">
            <field name="name">Quản Lý Văn Bản Đến</field>
            <field name="res_model">van_ban_den</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="van_ban_den_search" />
        </record>
    </data>
</odoo>
        
    