<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Kanban View -->
        <record id="view_dashboard_md_kanban" model="ir.ui.view">
            <field name="name">dashboard_md_kanban</field>
            <field name="model">dashboard_md</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_view" create="false">
                    <field name="total_van_ban_den"/>
                    <field name="total_van_ban_di"/>
                    <field name="total_nhan_su"/>
                    <field name="cong_viec_da_hoan_thanh_text"/>
                    <field name="cong_viec_dang_xu_ly_text"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="o_kanban_dashboard"
                                 style="display: flex; flex-direction: column; width: 100%; gap: 20px;">

                                <!-- Hàng 1: Tổng văn bản và nhân sự -->
                                <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
                                    <!-- Tổng văn bản đến -->
                                    <div class="oe_kanban_card"
                                         style="background: #fff3e0; border-radius: 10px; padding: 20px;
                                                box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
                                                min-width: 250px; flex: 1; text-align: center;">
                                        <h3 style="color: #d32f2f; font-size: 18px;">📩 Tổng văn bản đến</h3>
                                        <span style="font-size: 20px; font-weight: bold; color: #d32f2f;">
                                            <field name="total_van_ban_den"/>
                                        </span>
                                        <div style="margin-top: 10px; text-align: left;">
                                            <h4 style="font-size: 16px; color: #d32f2f;">📑 Văn bản đến gần đây:</h4>
                                            <field name="van_ban_den_text" style="white-space: pre-line; font-size: 14px;"/>
                                        </div>
                                        <div style="text-align: right; margin-top: 10px;">
                                        <a t-attf-href="/web#menu_id=107&amp;action=150&amp;model=van_ban_den&amp;view_type=list" class="btn btn-link" style="margin-top: 10px;" role="button">➡️ Xem thêm</a>
                                    </div>
                                    </div>

                                    <!-- Tổng văn bản đi -->
                                    <div class="oe_kanban_card"
                                         style="background: #e3f2fd; border-radius: 10px; padding: 20px;
                                                box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
                                                min-width: 250px; flex: 1; text-align: center;">
                                        <h3 style="color: #1976d2; font-size: 18px;">📤 Tổng văn bản đi</h3>
                                        <span style="font-size: 20px; font-weight: bold; color: #1976d2;">
                                            <field name="total_van_ban_di"/>
                                        </span>
                                        <div widget="html" style="margin-top: 10px; text-align: left;">
                                            <h4 style="font-size: 16px; color: #1565c0;">📑 Văn bản đi gần đây:</h4>
                                            <field name="van_ban_di_text" style="white-space: pre-line; font-size: 14px;"/>
                                        </div>
                                        <div style="text-align: right; margin-top: 10px;">
                                        <a t-attf-href="/web#menu_id=107&amp;action=146&amp;model=van_ban_di&amp;view_type=list" class="btn btn-link" style="margin-top: 10px;" role="button">➡️ Xem thêm</a>
                                    </div>
                                    </div>

                                    <!-- Tổng nhân sự -->
                                    <div class="oe_kanban_card"
                                         style="background: #e8f5e9; border-radius: 10px; padding: 20px;
                                                box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
                                                min-width: 250px; flex: 1; text-align: center;">
                                        <h3 style="color: #388e3c; font-size: 18px;">👥 Tổng nhân sự</h3>
                                        <span style="font-size: 20px; font-weight: bold; color: #388e3c;">
                                            <field name="total_nhan_su"/>
                                        </span>
                                        <div style="margin-top: 10px; text-align: left;">
                                            <h4 style="font-size: 16px; color: #388e3c;">👤 Nhân sự mới gần đây:</h4>
                                            <field name="nhan_vien_text" style="white-space: pre-line; font-size: 14px;"/>
                                        </div>
                                          <div style="text-align: right; margin-top: 10px;">
                                        <a t-attf-href="/web#menu_id=102&amp;action=142&amp;model=nhan_vien&amp;view_type=list" class="btn btn-link" style="margin-top: 10px;" role="button">➡️ Xem thêm</a>
                                    </div>
                                    </div>
                                </div>
                            <br/>

                                <!-- Hàng Công việc -->
                        <div style="display: flex; justify-content: space-between; gap: 20px; flex-wrap: nowrap;height:400px">
                            <!-- Công việc đã hoàn thành -->
                            <div class="oe_kanban_card"
                                style="background: #f1f8e9; border-radius: 10px; padding: 15px; box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1); flex: 1; text-align: center;">
                            <h3 style="color: #33691e; font-size: 18px;">✅ Công việc đã hoàn thành</h3>
                            <div style="margin-top: 10px; text-align: left;">
                                    <field name="cong_viec_da_hoan_thanh_text" style="white-space: pre-line; font-size: 14px;"/>
                                </div>
                            </div>

                                <!-- Công việc đang xử lý -->
                            <div class="oe_kanban_card"
                                style="background: #fff3e0; border-radius: 10px; padding: 15px;box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);flex: 1; text-align: center;">
                                <h3 style="color: #ff6f00; font-size: 18px;">🔄 Công việc đang xử lý</h3>
                                <div style="margin-top: 10px; text-align: left;">
                                    <field name="cong_viec_dang_xu_ly_text" style="white-space: pre-line; font-size: 14px;"/>
                                </div>
                            </div>

                            <!-- Công việc hoàn thành muộn -->
                            <div class="oe_kanban_card"
                                style="background: #ffebee; border-radius: 10px; padding: 15px; box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1); flex: 1; text-align: center;">
                                <h3 style="color: #ff6f00; font-size: 18px;">⏳ Công việc hoàn thành muộn</h3>
                                    <div style="margin-top: 10px; text-align: left;">
                                        <field name="cong_viec_hoan_thanh_muon_text" style="white-space: pre-line; font-size: 14px;"/>
                                    </div>
                                </div>
                                    <!-- Công việc đã nhận -->
                                <div class="oe_kanban_card"
                                    style="background: #e3f2fd; border-radius: 10px; padding: 15px;box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1); flex: 1; text-align: center;">
                                    <h3 style="color: #33691e; font-size: 18px;">📩 Công việc đã nhận</h3>
                                        <div style="margin-top: 10px; text-align: left;">
                                            <field name="cong_viec_da_nhan_text" style="white-space: pre-line; font-size: 14px;"/>
                                        </div>
                                    </div>
                                </div>
                               <div style="text-align: left; margin-top: 15px;">
                                    <a href="web#menu_id=107&amp;action=152&amp;model=cong_viec&amp;view_type=list" role="button" style="color: #007bff; font-size: 12px; font-weight: bold; text-decoration: none;">
                                        Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_dashboard_md" model="ir.actions.act_window">
            <field name="name">Dashboard</field>
            <field name="res_model">dashboard_md</field>
            <field name="view_mode">kanban</field>
        </record>
    </data>
</odoo>
